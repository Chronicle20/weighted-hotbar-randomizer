{
  "version": "1.0",
  "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
  "skills": {
    "mod-dev-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Minecraft Fabric mod development patterns for Java",
      "promptTriggers": {
        "keywords": [
          "mixin",
          "fabric",
          "minecraft",
          "hotbar",
          "inventory",
          "client",
          "keybinding",
          "screen",
          "gui",
          "hud",
          "tooltip",
          "item stack",
          "mod menu",
          "config"
        ],
        "intentPatterns": [
          "(create|add|implement|build).*?(mixin|screen|gui|keybind|config|handler|renderer)",
          "(fix|handle|debug).*?(client|render|tick|event|mixin)",
          "(add|implement).*?(feature|hotbar|randomize|weight|slot)",
          "(organize|structure|refactor).*?(mod|client|mixin|config)",
          "(how to|best practice).*?(fabric|mixin|mod|client|minecraft)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "src/main/java/**/*.java",
          "src/main/resources/**",
          "src/client/java/**/*.java"
        ],
        "pathExclusions": [],
        "contentPatterns": [
          "@Mixin",
          "@Inject",
          "FabricClientModInitializer",
          "ClientModInitializer"
        ]
      }
    }
  },
  "notes": {
    "enforcement_types": {
      "suggest": "Skill suggestion appears but doesn't block execution",
      "block": "Requires skill to be used before proceeding (guardrail)",
      "warn": "Shows warning but allows proceeding"
    },
    "priority_levels": {
      "critical": "Highest - Always trigger when matched",
      "high": "Important - Trigger for most matches",
      "medium": "Moderate - Trigger for clear matches",
      "low": "Optional - Trigger only for explicit matches"
    },
    "customization": {
      "pathPatterns": "Adjust to match your project structure",
      "keywords": "Add domain-specific terms relevant to your project",
      "intentPatterns": "Use regex for flexible user intent matching"
    }
  }
}
